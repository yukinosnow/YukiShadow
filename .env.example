# YukiShadow Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=YukiShadow
DEBUG=false
TIMEZONE=Asia/Shanghai

# ── LLM ───────────────────────────────────────────────────────────────────────
# Which provider to use by default: ollama | openai | anthropic
LLM_DEFAULT_PROVIDER=ollama

# Ollama (local – recommended for daily use)
# The ollama container maps port 11434 to the host, so localhost:11434 works
# whether YukiShadow runs on the host or in Docker (host-mode).
LLM_OLLAMA_BASE_URL=http://localhost:11434
LLM_OLLAMA_DEFAULT_MODEL=qwen3.5:27b
# Available models in the ollama container (docker exec -it ollama ollama list):
#   qwen3.5:27b   (default, ~17GB, good balance of speed and quality)
#   qwen3.5:35b   (~23GB, higher quality, slightly slower)
# Switch any skill to 35b: LLM_SKILL_OVERRIDES=reminder=ollama  (then override model per-provider)

# OpenAI (optional – for skills that need it)
LLM_OPENAI_API_KEY=
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_OPENAI_DEFAULT_MODEL=gpt-4o
# LM Studio / any OpenAI-compatible endpoint: just change LLM_OPENAI_BASE_URL

# Anthropic (optional)
LLM_ANTHROPIC_API_KEY=
LLM_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# Per-skill LLM overrides (comma-separated skill=provider pairs)
# Example: use Claude for code review, Ollama for everything else
# LLM_SKILL_OVERRIDES=code_review=anthropic,translation=openai
LLM_SKILL_OVERRIDES=

# ── Discord ───────────────────────────────────────────────────────────────────
# Get your bot token at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Right-click a Discord channel → Copy Channel ID (enable Developer Mode first)
DISCORD_NOTIFICATION_CHANNEL_ID=
DISCORD_COMMAND_PREFIX=!

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite+aiosqlite:///./yukishadow.db
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── MQTT / Jetson ─────────────────────────────────────────────────────────────
# Set MQTT_HOST to this machine's LAN IP so the Jetson can connect
MQTT_HOST=localhost
MQTT_PORT=1883

# ── Service ports ─────────────────────────────────────────────────────────────
ORCHESTRATOR_PORT=8080
